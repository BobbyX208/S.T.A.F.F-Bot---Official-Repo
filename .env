# Discord Configuration
DISCORD_TOKEN=your_bot_token_here

# Database Configuration (choose one)
# For PostgreSQL
DB_TYPE=postgresql
DB_HOST=localhost
DB_PORT=5432
DB_NAME=discord_bot
DB_USER=postgres
DB_PASSWORD=your_password

# For MySQL
# DB_TYPE=mysql
# DB_HOST=localhost
# DB_PORT=3306
# DB_NAME=discord_bot
# DB_USER=root
# DB_PASSWORD=your_password

# For JSON (fallback)
# DB_TYPE=json

# GitHub Configuration (for auto-pull)
GITHUB_REPO=yourusername/your-repo
GITHUB_BRANCH=main
GITHUB_POLL_INTERVAL=60  # seconds

# Bot Configuration
COMMAND_PREFIX=!
STAFF_ROLE_ID=your_staff_role_id